# Copy to .env and fill in. NEVER commit .env, NEVER paste keys into chat.
# Without these the bot runs on reproducible synthetic data (offline).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: alert transport (Discord/Slack/webhook). No-op if empty.
ALERT_WEBHOOK_URL=
