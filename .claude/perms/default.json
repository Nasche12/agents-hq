{
  "_comment": "Rechte-Profil fuer die Worker-Agents (belege, wochenreport, seo, rechnung, content, uptime, mail, video, ki, kommandant). Ersetzt --dangerously-skip-permissions (als root verboten). dontAsk laeuft headless: alles Erlaubte laeuft ohne Rueckfrage, alles Nicht-Erlaubte wird lautlos verweigert (statt zu haengen). Deny schlaegt Allow in JEDEM Scope – die Deny-Liste ist der eigentliche Schutz gegen Prompt-Injection ueber untrusted Input (E-Mails, Web-Inhalte).",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(sudo)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(wipefs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(init:*)",
      "Bash(systemctl:start*)",
      "Bash(systemctl:stop*)",
      "Bash(systemctl:restart*)",
      "Bash(systemctl:reload*)",
      "Bash(systemctl:enable*)",
      "Bash(systemctl:disable*)",
      "Bash(systemctl:mask*)",
      "Bash(systemctl:kill*)",
      "Bash(service:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(crontab:*)",
      "Bash(at:*)",
      "Bash(passwd:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(groupadd:*)",
      "Bash(chpasswd:*)",
      "Bash(visudo:*)",
      "Bash(iptables:*)",
      "Bash(ip6tables:*)",
      "Bash(ufw:*)",
      "Bash(nft:*)",
      "Bash(firewall-cmd:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(dnf:*)",
      "Bash(yum:*)",
      "Bash(pacman:*)",
      "Bash(snap:*)",
      "Bash(chown:*)",
      "Bash(chmod:*)",
      "Bash(mount:*)",
      "Bash(umount:*)",
      "Bash(modprobe:*)",
      "Bash(insmod:*)",
      "Bash(rmmod:*)",
      "Edit(/etc/**)",
      "Write(/etc/**)",
      "Edit(/root/**)",
      "Write(/root/**)",
      "Edit(/usr/**)",
      "Write(/usr/**)",
      "Edit(/bin/**)",
      "Write(/bin/**)",
      "Edit(/boot/**)",
      "Write(/boot/**)",
      "Edit(/var/**)",
      "Write(/var/**)",
      "Edit(/etc/passwd)",
      "Write(/etc/passwd)"
    ]
  }
}
