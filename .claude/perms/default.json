{
  "_comment": "Fallback-Profil fuer Worker-Agents ohne eigenes Profil (belege, wochenreport, rechnung, mail, video, ki, kommandant). Die untrusted-Input-Agents (content-recherche, seo-audit, uptime-waechter) haben je ein ENGERES eigenes Profil. dontAsk laeuft headless; Deny schlaegt Allow. EHRLICHE GRENZE: 'curl' bleibt erlaubt (uptime/measure/discord brauchen es) -> reine Deny-Liste ist KEIN vollstaendiger Exfil-Schutz. Echter Egress-Schutz = OS-Firewall (nftables-Allowlist). Deny deckt Eskalation, FS-/Service-/Paket-Mutation und Remote-Exec/Tunnel (nc/ssh/scp/wget/...) ab.",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Bash"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(sudo)",
      "Bash(su:*)",
      "Bash(doas:*)",
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shred:*)",
      "Bash(wipefs:*)",
      "Bash(fdisk:*)",
      "Bash(parted:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(poweroff:*)",
      "Bash(init:*)",
      "Bash(systemctl:start*)",
      "Bash(systemctl:stop*)",
      "Bash(systemctl:restart*)",
      "Bash(systemctl:reload*)",
      "Bash(systemctl:enable*)",
      "Bash(systemctl:disable*)",
      "Bash(systemctl:mask*)",
      "Bash(systemctl:kill*)",
      "Bash(service:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(crontab:*)",
      "Bash(at:*)",
      "Bash(passwd:*)",
      "Bash(useradd:*)",
      "Bash(userdel:*)",
      "Bash(usermod:*)",
      "Bash(groupadd:*)",
      "Bash(chpasswd:*)",
      "Bash(visudo:*)",
      "Bash(iptables:*)",
      "Bash(ip6tables:*)",
      "Bash(ufw:*)",
      "Bash(nft:*)",
      "Bash(firewall-cmd:*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(dnf:*)",
      "Bash(yum:*)",
      "Bash(pacman:*)",
      "Bash(snap:*)",
      "Bash(chown:*)",
      "Bash(chmod:*)",
      "Bash(mount:*)",
      "Bash(umount:*)",
      "Bash(modprobe:*)",
      "Bash(insmod:*)",
      "Bash(rmmod:*)",
      "Bash(nc:*)",
      "Bash(ncat:*)",
      "Bash(netcat:*)",
      "Bash(socat:*)",
      "Bash(scp:*)",
      "Bash(sftp:*)",
      "Bash(ssh:*)",
      "Bash(telnet:*)",
      "Bash(wget:*)",
      "Bash(ftp:*)",
      "Bash(tftp:*)",
      "Bash(rsync:*)",
      "Edit(/etc/**)",
      "Write(/etc/**)",
      "Edit(/root/**)",
      "Write(/root/**)",
      "Edit(/usr/**)",
      "Write(/usr/**)",
      "Edit(/bin/**)",
      "Write(/bin/**)",
      "Edit(/boot/**)",
      "Write(/boot/**)",
      "Edit(/var/**)",
      "Write(/var/**)",
      "Edit(/etc/passwd)",
      "Write(/etc/passwd)"
    ]
  }
}
