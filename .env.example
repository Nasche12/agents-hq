# Claude Code Auth für unbeaufsichtigte (Cron-)Läufe.
# Der Wrapper bin/run-agent.sh sourcet diese .env und exportiert den Key an claude.
# Key von console.anthropic.com. Alternativ: der Cron-User loggt sich einmal via `claude` ein.
ANTHROPIC_API_KEY=

# Umami Analytics – Zugang für den wochenreport-Agent
UMAMI_BASE_URL=https://analytics.naschberger.info
UMAMI_USERNAME=dein-benutzername
UMAMI_PASSWORD=dein-passwort

# Optional: Discord-Bot (für docs/DISCORD-SETUP.md) – ermöglicht die Zwei-Wege-Bridge
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Bridge (server.js pollt Discord -> HQ). Kanal für Kommandos/Freigaben und für Status-Logs:
DISCORD_COMMAND_CHANNEL=freigaben
DISCORD_LOG_CHANNEL=agent-logs
DISCORD_POLL_SECONDS=12
# DISCORD_BRIDGE=off       # setzen, um das Discord-Polling im server.js abzuschalten
# Scheduler: feuert fällige Agents aus config/schedule.json von selbst (leichte automatisch,
# schwere fragen in #freigaben nach 'run <agent>'). Master postet die Lage täglich zur Uhrzeit.
# DISCORD_SCHEDULER=off    # setzen, um den Auto-Scheduler abzuschalten
DISCORD_MASTER_DAILY=07:30 # leer lassen für keine tägliche Master-Lage
# Heartbeat: postet 3x/Tag "alles aktiv" (mit Uptime-Zahlen) nach DISCORD_LOG_CHANNEL.
DISCORD_HEARTBEAT=08:00,14:00,20:00 # leer lassen zum Abschalten

# Optional: E-Mail-Versand über Plesk (genutzt von bin/send-mail.py)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Optional: Port 587 (STARTTLS, Default) oder 465 (SSL); Absender falls != SMTP_USER
SMTP_PORT=587
SMTP_FROM=
