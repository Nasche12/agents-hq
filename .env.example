# Claude Code Auth für unbeaufsichtigte (Cron-)Läufe.
# Der Wrapper bin/run-agent.sh sourcet diese .env und exportiert den Key an claude.
# Key von console.anthropic.com. Alternativ: der Cron-User loggt sich einmal via `claude` ein.
ANTHROPIC_API_KEY=

# Umami Analytics – Zugang für den wochenreport-Agent
UMAMI_BASE_URL=https://analytics.naschberger.info
UMAMI_USERNAME=dein-benutzername
UMAMI_PASSWORD=dein-passwort

# Optional: Discord-Bot (für docs/DISCORD-SETUP.md)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=wi

# Optional: E-Mail-Versand über Plesk (genutzt von bin/send-mail.py)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Optional: Port 587 (STARTTLS, Default) oder 465 (SSL); Absender falls != SMTP_USER
SMTP_PORT=587
SMTP_FROM=
