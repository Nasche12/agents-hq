# Claude Code Auth für unbeaufsichtigte (Cron-)Läufe.
# Der Wrapper bin/run-agent.sh sourcet diese .env und exportiert den Key an claude.
# Key von console.anthropic.com. Alternativ: der Cron-User loggt sich einmal via `claude` ein.
ANTHROPIC_API_KEY=

# Umami Analytics – Zugang für den wochenreport-Agent
UMAMI_BASE_URL=https://analytics.naschberger.info
UMAMI_USERNAME=dein-benutzername
UMAMI_PASSWORD=dein-passwort

# Optional: Discord-Bot (für docs/DISCORD-SETUP.md) – Steuerung per Slash-Commands + Bridge
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Für echte Slash-Commands (/status, /run, /ja …). Beides im Discord Developer Portal:
#   DISCORD_APP_ID    = Application ID (General Information)
#   DISCORD_PUBLIC_KEY = Public Key (General Information) – nötig, damit server.js die
#                        signierten Interactions verifizieren kann.
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
# Bridge (server.js pollt Discord -> HQ, für freie Texte/Fragen). Kanäle:
DISCORD_COMMAND_CHANNEL=freigaben
DISCORD_LOG_CHANNEL=agent-logs
DISCORD_POLL_SECONDS=12
# DISCORD_BRIDGE=off       # setzen, um das Discord-Text-Polling abzuschalten (Slash bleibt aktiv)
# Scheduler: feuert fällige Agents aus config/schedule.json (leichte automatisch, schwere fragen
# in #freigaben nach /ja bzw. /nein). Zeitbasis = 'zeitzone' in schedule.json (TZ-fest).
# DISCORD_SCHEDULER=off    # setzen, um den Auto-Scheduler abzuschalten
DISCORD_MASTER_DAILY=07:30 # eine knappe Tages-Lage; leer lassen zum Abschalten
# Heartbeat (Default: AUS). Uhrzeiten kommagetrennt setzen, um Lebenszeichen zu posten:
DISCORD_HEARTBEAT=          # z. B. 08:00,20:00 – leer = kein Heartbeat-Spam

# Optional: E-Mail-Versand über Plesk (genutzt von bin/send-mail.py)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Optional: Port 587 (STARTTLS, Default) oder 465 (SSL); Absender falls != SMTP_USER
SMTP_PORT=587
SMTP_FROM=

# ---- Doppelspur fuer die on-demand-Agents: headless (API/IMAP) NEBEN interaktivem MCP ----
# Prinzip: laeuft der Agent unbeaufsichtigt im Cron (kein MCP da) und ein Key ist gesetzt,
# nutzt er den API-/IMAP-Weg; laeuft er interaktiv aus einer Session, nutzt er den MCP.

# Higgsfield-Video headless (video-producent/ki-influencer). Key aus cloud.higgsfield.ai.
# Basis-URL/Pfade bitte gegen die offizielle Doku bestaetigen, sobald du den Key hast.
HIGGSFIELD_API_KEY=
HIGGSFIELD_API_BASE=https://platform.higgsfield.ai

# Posteingang lesen headless (mail-/akquise-Agent) ueber Plesk-IMAP. Senden laeuft ueber SMTP oben.
IMAP_HOST=
IMAP_USER=
IMAP_PASS=
IMAP_PORT=993

# Dashboard Basic-Auth (schuetzt agents.naschberger.info hinter dem Reverse-Proxy).
# Beide setzen -> Login noetig. Leer -> API GESPERRT (401) — NICHT mehr offen.
# Selbst befuellen (kein Default-Passwort mehr!), z. B.:  openssl rand -base64 18
HQ_USER=
HQ_PASS=
# HQ_OPEN=1   # NUR lokale Entwicklung: API ohne Auth erlauben. In Produktion NIEMALS setzen.

# ---- Betrieb: Haenge-Schutz, Watchdog, Log-Rotation, Backup ----
# HQ_RUN_TIMEOUT=1800     # harte Obergrenze je Agent-Lauf in Sekunden (Default 30 min)
# HQ_STUCK_MINUTES=45     # Watchdog: 'running' ohne Lebenszeichen so lange -> als tot freigeben (Default 45)
# HQ_LOG_KEEP=40          # so viele Pro-Lauf-Logs je Agent behalten, Rest wird geloescht (Default 40)
# HQ_BACKUP_DAILY=03:30   # taeglicher Backup-Lauf (bin/backup.sh) via Scheduler; leer = aus
# BACKUP_DIR=/pfad/auf/anderem/volume   # Backup-Ziel (Default: <repo>/../agents-hq-backups)
# BACKUP_KEEP=14          # so viele Backup-Staende behalten (Default 14)
